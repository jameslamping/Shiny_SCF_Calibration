# =============================================================================
# R / Shiny project .gitignore
# =============================================================================

# R session artifacts
.Rhistory
.RData
*.RData
.Rproj.user/
*.Rproj

# App session state / cache snapshots
*.json

# R package build outputs
*.tar.gz
*.zip

# renv — commit the lockfile and activate script; ignore the library cache
# (collaborators run `renv::restore()` to rebuild the library locally)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Large data inputs — too big for git; document in README
*.nc
*.gdb
*.gdb/
*.tif
*.tiff
*.geotiff

# Temporary / scratch output files
*.tmp
Rplots.pdf

# Shiny app logs
*.log
rsconnect/

# Local data inputs — too large for git; see data_raw/ERA-Interim/README.txt
# for ERA-Interim setup instructions
data_raw/

# user paths
paths.rtf

# Claude Code project instructions (local only)
CLAUDE.md
